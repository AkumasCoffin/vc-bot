# =========================
# Discord Auth / Target VC
# =========================
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
VOICE_CHANNEL_ID=

# =========================
# OPTIONAL (these all have defaults in index.js)
# =========================

# How long to wait before leaving VC (ms). Default: 15000 (15s)
LEAVE_DELAY_MS=15000

# Rate-limit protection for the voice-status endpoint:
# Default: 15000 (15s) when the "key" is the same
VC_STATUS_MIN_INTERVAL_MS=15000

# Default: 750ms when the "key" changes (e.g. humans count changes)
VC_STATUS_MIN_INTERVAL_ON_CHANGE_MS=750

# Reroll status while humans=0 (empty). Default in YOUR file: 0 (disabled)
# Example: reroll every 10 minutes:
VC_IDLE_ROTATE_MS=600000

# Debug logging toggle used by your file (NOTE: name is DEBUG_STATUS)
# Set to 1 to enable extra logs
DEBUG_STATUS=1

# Comma/space separated Discord user IDs to detect in the VC
VC_WATCH_USER_IDS=400406998715203594

# What gets prefixed when it appends the detected user(s)
VC_WATCH_PREFIX= 👀

# How it injects the watch users:
# auto   = append only if your template doesn't already use {watch}/{watchers}/{watchcount}
# always = always append
# never  = never append automatically (only shows if your templates use the placeholders)
VC_WATCH_APPEND_MODE=auto
